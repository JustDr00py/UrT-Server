# ─────────────────────────────────────────────────────────────────────────────
# Urban Terror Server – Environment Configuration
# Copy this file to .env and customize before running docker compose up
# ─────────────────────────────────────────────────────────────────────────────

# ── Server Identity ───────────────────────────────────────────────────────────
URT_HOSTNAME=My Urban Terror Server [TS 16p]
URT_MOTD=Welcome! Play fair, have fun.
URT_ADMIN_NAME=Admin

# ── Passwords (CHANGE THESE!) ─────────────────────────────────────────────────
URT_RCON_PASSWORD=changeme_rcon
URT_REFEREE_PASSWORD=changeme_ref
URT_SERVER_PASSWORD=          # leave empty for a public server

# ── Network ───────────────────────────────────────────────────────────────────
URT_PORT=27960
URT_PUBLIC=2                  # 2=internet, 1=LAN only, 0=private
URT_FPS=40                    # server framerate; 40 is a smooth sweet spot for 16p
URT_SNAPS=20
URT_MAX_RATE=50000            # max bytes/sec per client (modern connections)
URT_MIN_RATE=8000
URT_MAX_PING=250              # players above this are kicked
URT_MIN_PING=0

# ── Player Limits ─────────────────────────────────────────────────────────────
URT_MAX_CLIENTS=16

# ── Gameplay ──────────────────────────────────────────────────────────────────
# Game types: 0=FFA 1=LMS 2=TDM 3=TS 4=FTL 5=CAH 6=CTF 7=Bomb
URT_GAMETYPE=4                # 4 = Team Survivor (TS)
URT_TIMELIMIT=20              # minutes per map
URT_FRAGLIMIT=0               # irrelevant in TS; leave 0
URT_ROUNDLIMIT=0              # 0 = unlimited rounds (time limit governs)
URT_CAPTURELIMIT=0
URT_OVERTIME=1                # 1=allow overtime when tied

# Friendly fire: 0=off 1=half damage 2=full 3=reflected back
URT_FRIENDLY_FIRE=1

URT_TEAM_BALANCE=1            # auto-balance teams on map end
URT_GEAR=0                    # 0=all weapons; restrict with bitmask if desired

# Physics
URT_GRAVITY=800
URT_SPEED=320
URT_JUMP_VELOCITY=270
URT_STAMINA=0                 # 0=infinite sprint (casual), 1=enabled

# Spawn protection (seconds)
URT_RESPAWN_PROTECTION=0

# Client-side movement smoothing
URT_SMOOTH_CLIENTS=1

# ── Warmup ────────────────────────────────────────────────────────────────────
URT_DO_WARMUP=1
URT_WARMUP_TIME=15            # seconds

# ── Voting ────────────────────────────────────────────────────────────────────
URT_ALLOW_VOTE=1
URT_VOTE_FLAGS=255            # 255=all votes allowed
URT_VOTE_LIMIT=5
URT_MAP_VOTE_DELAY=5

# ── Security ──────────────────────────────────────────────────────────────────
URT_PURE=1                    # enforce pure server (recommended)
URT_FLOOD_PROTECT=1
URT_ANTICHEAT=0               # set to 1 if your server supports UrT auth
