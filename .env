# ─────────────────────────────────────────────────────────────────────────────
# Urban Terror Server – Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# ── Server Identity ───────────────────────────────────────────────────────────
URT_HOSTNAME=My Urban Terror Server [TS 16p]
URT_MOTD=Welcome! Play fair, have fun.
URT_ADMIN_NAME=Admin

# ── Passwords (CHANGE THESE!) ─────────────────────────────────────────────────
URT_RCON_PASSWORD=changeme_rcon
URT_REFEREE_PASSWORD=changeme_ref
# Leave URT_SERVER_PASSWORD empty for a public server
URT_SERVER_PASSWORD=

# ── Network ───────────────────────────────────────────────────────────────────
URT_PORT=27960
# URT_PUBLIC: 2=internet, 1=LAN only, 0=private
URT_PUBLIC=2
# Server framerate – 40 is a smooth sweet spot for 16 players
URT_FPS=40
# snaps must equal sv_fps so clients get a position update every server frame
URT_SNAPS=40
# Max/min bytes per second per client
URT_MAX_RATE=50000
URT_MIN_RATE=8000
# 0 = no ping limit; set e.g. 300 to kick high-ping players
URT_MAX_PING=0
URT_MIN_PING=0

# ── Player Limits ─────────────────────────────────────────────────────────────
URT_MAX_CLIENTS=16

# ── Gameplay ──────────────────────────────────────────────────────────────────
# Game types: 0=FFA 1=LMS 2=TDM 4=TS 5=CAH 6=CTF 7=Bomb
URT_GAMETYPE=4
URT_TIMELIMIT=20
# Fraglimit is irrelevant in TS; leave 0
URT_FRAGLIMIT=0
# 0 = unlimited rounds (time limit governs)
URT_ROUNDLIMIT=0
URT_CAPTURELIMIT=0
# 1 = allow overtime when tied
URT_OVERTIME=1

# Friendly fire: 0=off 1=half damage 2=full 3=reflected back
URT_FRIENDLY_FIRE=1

# Auto-balance teams on map end
URT_TEAM_BALANCE=1
# Weapon bitmask – 0 = all weapons allowed
URT_GEAR=0

# ── Physics ───────────────────────────────────────────────────────────────────
URT_GRAVITY=800
URT_SPEED=320
URT_JUMP_VELOCITY=270
# 0 = infinite sprint (casual); 1 = limited stamina
URT_STAMINA=0
# Spawn protection in seconds
URT_RESPAWN_PROTECTION=0
# Interpolate movement between server frames
URT_SMOOTH_CLIENTS=1

# ── Warmup ────────────────────────────────────────────────────────────────────
URT_DO_WARMUP=1
URT_WARMUP_TIME=15

# ── Voting ────────────────────────────────────────────────────────────────────
URT_ALLOW_VOTE=1
# 255 = all vote types allowed
URT_VOTE_FLAGS=255
URT_VOTE_LIMIT=5
URT_MAP_VOTE_DELAY=5

# ── Security ──────────────────────────────────────────────────────────────────
# 1 = enforce pure server (recommended)
URT_PURE=1
URT_FLOOD_PROTECT=1
# Set to 1 if your server supports UrT auth/anticheat
URT_ANTICHEAT=0

# ── Client Auto-download ───────────────────────────────────────────────────────
# 1 = players auto-download missing maps/pk3s on join
URT_ALLOW_DOWNLOAD=1
# Optional: HTTP URL hosting your pk3 files for faster downloads
# e.g. URT_DL_URL=http://yourserver.com/urt-files/
URT_DL_URL=

# Space-separated list of maps NOT in the rotation that you load via rcon
# (g_mapConfigs needs a cfg file for each map to restore sv_allowdownload)
URT_EXTRA_MAPS=padkitchen_f1
